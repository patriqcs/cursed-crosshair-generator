PORT=3000
DATA_DIR=/data

ADMIN_USER=admin
ADMIN_PASSWORD=

SESSION_SECRET=

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# === Produktion / Sicherheit ===
# In Produktion setzen: erzwingt Secure-Cookie und Turnstile-fail-closed.
NODE_ENV=production
# Anzahl vertrauenswürdiger Proxy-Hops (Cloudflare Tunnel = 1). NICHT 'true'.
# WICHTIG: Der Container-Port darf NUR über den Tunnel erreichbar sein, sonst
# kann CF-Connecting-IP gespooft und das Rate-Limit umgangen werden.
TRUST_PROXY=1
# Nur setzen, wenn bewusst OHNE Captcha betrieben (sonst in Prod fail-closed):
# ALLOW_NO_CAPTCHA=true
# Nur für lokales Plain-HTTP-Testing (schaltet das Secure-Cookie ab):
# COOKIE_INSECURE=true
# Obergrenze offener Submissions (DoS-Backstop):
# MAX_PENDING_SUBMISSIONS=500
